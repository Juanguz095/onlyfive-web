{
  "kind": "collectionType",
  "collectionName": "articulos",
  "info": {
    "singularName": "articulo",
    "pluralName": "articulos",
    "displayName": "Articulo"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "titulo": {
      "type": "string",
      "required": true
    },
    "contenido": {
      "type": "richtext"
    },
    "resumen": {
      "type": "text"
    },
    "imagen": {
      "type": "string"
    },
    "categoria": {
      "type": "string"
    },
    "estado": {
      "type": "enumeration",
      "enum": [
        "borrador",
        "publicado"
      ],
      "default": "borrador"
    },
    "fecha_publicacion": {
      "type": "datetime"
    },
    "autor": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    }
  }
}
